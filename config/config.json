{
  "$schema": "../schema.json",
  "title": "QRScout",
  "page_title": "4020 Scouting",
  "sections": [

    {
      "name": "Match Scouting or Pit Scouting",
      "preserveDataOnReset": false,
      "fields":[
        {
          "title": "Is_Match_Scouting",
          "type": "boolean",
          "required": false,
          "code": "toggleTest",
          "defaultValue": true
        }
      ]
    },
    { 
      "name": "Pre-Pit Scouting",
      "preserveDataOnReset": false,
      "visibleWhen": { "code": "toggleTest", "equals": false},
      "fields":[
        {
          "title": "Scouter_Initials_Pre",
          "type": "text",
          "required": true,
          "rows": 1,
          "code": "scouter"
        },
        {
          "title": "Team_Number_Pre",
          "type": "text",
          "required": true,
          "rows": 1,
          "code": "teamNumber"
        }
      ]
    },
    {
      "name": "Pit Scouting",
      "preserveDataOnReset": false, 
      "visibleWhen": { "code": "toggleTest", "equals": false},
            "fields":[
        {
          "code": "hp",
          "title": "Hopper_Size",
          "type": "select",
          "choices": {
            "small": "Small",
            "med": "Med",
            "large": "Large",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        }
      ]
    },
    {
      "name": "Prematch",
      "preserveDataOnReset": false,
      "visibleWhen": { "code": "toggleTest", "equals": true},
      "fields": [
        {
          "title": "Scouter_Initials",
          "type": "text",
          "required": true,
          "rows": 1,
          "code": "scouter"
        },
        {
          "title": "Match_Number",
          "type": "text",
          "required": true,
          "rows": 1,
          "code": "match"
        },
        {
          "title": "Alliance_ID",
          "type": "select",
          "required": true,
          "code": "allianceId",
          "choices": {
            "default": "",
            "r1": "Red 1",
            "r2": "Red 2",
            "r3": "Red 3",
            "b1": "Blue 1",
            "b2": "Blue 2",
            "b3": "Blue 3"
          },
          "defaultValue": "default"
        },
        {
          "title": "Team_Number",
          "type": "text",
          "required": true,
          "rows": 1,
          "code": "teamNumber"
        },
        {
          "title": "Starting_Location",
          "type": "select",
          "choices": {
            "depot": "Depot",
            "middle": "Middle",
            "outpost": "Outpost",
            "noShow": "No Show",
            "default": ""
          },
          "defaultValue": "default",
          "required": false,
          "code": "autoStart"
        }
      ]
    },
    {
      "name": "Auto",
      "visibleWhen": { "code": "toggleTest", "equals": true },
      "fields": [
        {
          "code": "aa",
          "title": "Auto_Accuracy",
          "type": "select",
          "choices": {
            "0": "0%",
            "25": "25%",
            "50": "50%",
            "75": "75%",
            "100": "100%",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
        {
          "code": "ti",
          "title": "Type_Of_Intake",
          "type": "select",
          "choices": {
            "floor": "Floor",
            "outpost": "Outpost",
            "both": "Both",
            "none": "None",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
        {
          "code": "c",
          "title": "Climbed",
          "type": "select",
          "choices": {
            "yes": "Yes",
            "no": "No",
            "attempted": "Attempted",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
          {
          "code": "sn",
          "title": "Speed_to_neutral_pile",
          "type": "select",
          "choices": {
            "none": "Did_not_attempt",
            "great": "Fast_(2_sec_or_less)",
            "good": "Med_(3-4_sec)",
            "decent": "Slow_(4+_sec)"
          },
          "defaultValue": "default",
          "required": false
        },
        {
          "code": "ha",
          "title": "Had_Advantage",
          "type": "select",
          "choices": {
            "yes": "Yes",
            "no": "No",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
        {
          "code": "fp",
          "title": "Fuel_pile_disruption",
          "type": "select",
          "choices": {
            "bad": "Did_not_attempt",
            "minor": "Minor",
             "Major": "Major",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        }
      ]
    },
    {
      "name": "Teleop",
      "visibleWhen": { "code": "toggleTest", "equals": true },
      "fields": [
        {
          "code": "tol",
          "title": "Time_to_get_off_Latter",
          "type": "select",
          "choices": {
            "fast(1-3)": "Fast(1-3)",
            "med(4-6)": "Med(4-6)",
            "slow(7+)": "Slow(7+)",
            "notAtempted": "Not_Attempted",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
        {
          "code": "or",
          "title": "Can_go_over_Ramp",
          "type": "select",
          "choices": {
            "yes": "Yes",
            "no": "No",
            "notAtempted": "Not_Attempted",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
        {
          "code": "ta",
          "title": "Teleop_Accuracy",
          "type": "select",
          "choices": {
            "0": "0%",
            "25": "25%",
            "50": "50%",
            "75": "75%",
            "100": "100%",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
        {
          "code": "tr",
          "title": "Teleop_Range",
          "type": "select",
          "choices": {
            "short": "Short",
            "mid": "Mid",
            "far": "Far",
            "all": "All",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
        {
          "code": "ie",
          "title": "Intake_Effectiveness",
          "type": "select",
          "choices": {
            "terrible": "Terrrible",
            "bad": "Bad",
            "mid": "Mid",
            "great": "Great",
            "awesome": "Awesome",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
        {
            "code": "s",
            "title": "Type_of_Shuttling",
            "type": "select",
            "choices": {
              "shooting": "Shooting",
              "push": "Push",
              "noAttempt": "Not_Attempted",
              "default": ""
            },
            "defaultValue": "default",
            "required": false
        },  
        {
          "code": "afo",
          "title": "Attempt_to_Fill_Up_Outpost",
          "type": "select",
          "choices": {
            "yes": "Yes",
            "no": "No",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
        {
          "code": "hc",
          "title": "Hopper_Cycles",
          "type": "counter",
          "defaultValue": 0,
          "min": 0,
          "bgcolor": "bg-emerald-500",
          "required": false
        }
      ]
    },
    {
      "name": "Endgame Tower",
      "visibleWhen": { "code": "toggleTest", "equals": true },
      "fields": [
        {
          "code": "ep",
          "title": "End_Position",
          "type": "select",
          "choices": {
            "notClimbed": "Not Climbed",
            "l1": "L1",
            "l2": "L2",
            "l3": "L3",
            "failed": "Failed",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        }
      ]
    },
    {
      "name": "Defense/Fouls",
      "visibleWhen": { "code": "toggleTest", "equals": true },
      "fields": [
        {
          "code": "da",
          "title": "Defense_Amount",
          "type": "select",
          "choices": {
            "little": "None or very little",
            "moderate": "Moderate amount",
            "most": "Most of the time",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
        {
          "code": "de",
          "title": "Defense_Effectiveness",
          "type": "select",
          "choices": {
            "no": "No defense played",
            "poor": "Poor",
            "ok": "OK",
            "great": "Excellent",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
        {
          "code": "foul",
          "title": "Fouls",
          "type": "select",
          "choices": {
            "na": "Forgot to notice",
            "clean": "None noticed - clean",
            "1or2": "1 or 2 regular fouls",
            "multiple": "Tech foul or multiple regular",
            "aLot": "Fouling machine!"
          },
          "defaultValue": "na",
          "required": false
        }
      ]
    },
    {
      "name": "Evaluation",
      "visibleWhen": { "code": "toggleTest", "equals": true },
      "fields": [
        {
          "code": "hs",
          "title": "Average_Hopper_Size_When_Scoring",
          "type": "select",
          "choices": {
            "small(0-20)": "Small(0-20)",
            "med(21-40)": "Med(21-40)",
            "large(41+)": "Large(41+)",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
        {
          "code": "j",
          "title": "Jamming",
          "type": "select",
          "choices": {
            "yes": "Yes",
            "no": "No",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
        {
          "code": "ds",
          "title": "Driver_Skill",
          "type": "select",
          "choices": {
            "na": "Not Noticed",
            "hindrance": "Hindrance",
            "poor": "Poor",
            "fair": "Fair",
            "good": "Mostly good",
            "great": "Very good"
          },
          "defaultValue": "na",
          "required": false
        },
        {
          "code": "rd",
          "title": "Robot_Died",
          "type": "select",
          "choices": {
            "no": "No",
            "yes": "Yes",
            "temporarily": "Temporarily",
            "default": ""
          },
          "defaultValue": "default",
          "required": false
        },
        {
          "code": "to",
          "title": "Tipped_Over",
          "type": "boolean",
          "defaultValue": false,
          "required": false
        },
        {
          "code": "co",
          "title": "Comments",
          "type": "text",
          "required": false,
          "rows": 3,
          "placeholder": "What was noteworthy or unusual about this performance? (defense, penalties, reliablity, etc.)"
        }
      ]
    }
  ]
}
